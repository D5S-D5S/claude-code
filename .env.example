# Shopify Store Credentials
# Get these from: Shopify Admin > Settings > Apps > Develop Apps
SHOPIFY_STORE_URL=thepropcenter.myshopify.com
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_ACCESS_TOKEN=your_admin_api_access_token_here
SHOPIFY_API_VERSION=2024-01

# AI APIs
ANTHROPIC_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Social Media (for direct posting - alternative to Make.com)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_account_id_here
TIKTOK_ACCESS_TOKEN=your_tiktok_token_here

# Make.com (optional - for webhook-based automation)
MAKE_WEBHOOK_URL=your_make_webhook_url_here
