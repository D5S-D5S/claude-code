{% comment %}
  The Prop Center — Luxury Product Page Template v2
  Inspired by high-converting event/luxury brand PDPs
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign featured_image   = current_variant.featured_image | default: product.featured_image -%}
{%- assign on_sale          = false -%}
{%- if current_variant.compare_at_price > current_variant.price -%}
  {%- assign on_sale = true -%}
  {%- assign savings_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
{%- endif -%}

{{ 'luxury-overrides.css' | asset_url | stylesheet_tag }}

<div class="lp" data-product-id="{{ product.id }}">

  {%- comment %} ── BREADCRUMB ── {% endcomment %}
  <nav class="lp__breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      {%- for col in product.collections limit: 1 -%}
        <li><a href="{{ col.url }}">{{ col.title }}</a></li>
      {%- endfor -%}
      <li aria-current="page">{{ product.title | truncate: 40 }}</li>
    </ol>
  </nav>

  <div class="lp__layout">

    {%- comment %} ══════════════════════════════════════
        LEFT — GALLERY
    ══════════════════════════════════════ {% endcomment %}
    <div class="lp__gallery">

      {%- comment %} Vertical thumbnail strip {% endcomment %}
      {%- if product.images.size > 1 -%}
        <div class="lp__thumbstrip">
          {%- for img in product.images limit: 8 -%}
            <button
              class="lp__thumb {% if forloop.first %}is-active{% endif %}"
              data-src="{{ img | image_url: width: 1200 }}"
              data-alt="{{ img.alt | escape }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img src="{{ img | image_url: width: 120 }}" alt="{{ img.alt | escape }}" width="120" height="120" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment %} Main image {% endcomment %}
      <div class="lp__main-img-wrap">
        {%- if on_sale -%}
          <span class="lp__badge-img">Save {{ savings_pct }}%</span>
        {%- endif -%}
        <img
          id="lp-main-img"
          src="{{ featured_image | image_url: width: 1200 }}"
          alt="{{ featured_image.alt | escape }}"
          width="1200"
          height="{{ 1200 | divided_by: featured_image.aspect_ratio | round }}"
          loading="eager"
        >
        {%- if product.images.size > 1 -%}
          <button class="lp__arrow lp__arrow--prev" aria-label="Previous">&#8592;</button>
          <button class="lp__arrow lp__arrow--next" aria-label="Next">&#8594;</button>
        {%- endif -%}
      </div>

    </div>{%- comment %} /.lp__gallery {% endcomment %}

    {%- comment %} ══════════════════════════════════════
        RIGHT — PRODUCT INFO
    ══════════════════════════════════════ {% endcomment %}
    <div class="lp__info">

      {%- comment %} Category label {% endcomment %}
      {%- for col in product.collections limit: 1 -%}
        <p class="lp__category">{{ col.title }}</p>
      {%- endfor -%}

      {%- comment %} Title {% endcomment %}
      <h1 class="lp__title">{{ product.title }}</h1>

      {%- comment %} Judge.me star rating {% endcomment %}
      <div class="lp__reviews-row">
        {%- render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', jm_style: '', concierge_install: true, product: product -%}
        <a class="lp__reviews-link" href="#lp-reviews">See all reviews</a>
      </div>

      {%- comment %} Price + savings badge {% endcomment %}
      <div class="lp__price" id="lp-price">
        {%- if on_sale -%}
          <span class="lp__price-sale">{{ current_variant.price | money }}</span>
          <span class="lp__price-was">{{ current_variant.compare_at_price | money }}</span>
          <span class="lp__save-badge">Save {{ savings_pct }}%</span>
        {%- else -%}
          <span class="lp__price-reg">{{ current_variant.price | money }}</span>
        {%- endif -%}
      </div>

      {%- comment %} Feature strip — 3 quick reassurances {% endcomment %}
      <ul class="lp__features">
        <li>
          <svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9 1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
          Free UK Delivery on orders £150+
        </li>
        <li>
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Premium Event-Grade Quality
        </li>
        <li>
          <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
          Fast Dispatch · Next-Day Available
        </li>
      </ul>

      {%- comment %} Variant selectors {% endcomment %}
      {%- unless product.has_only_default_variant -%}
        <div class="lp__variants" id="lp-variants">
          {%- for option in product.options_with_values -%}
            <div class="lp__option">
              <p class="lp__option-label">
                {{ option.name }}: <strong class="lp__option-val" data-opt="{{ forloop.index0 }}">{{ option.selected_value }}</strong>
              </p>
              {%- if option.name == 'Color' or option.name == 'Colour' -%}
                <div class="lp__swatches" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <button
                      class="lp__swatch {% if option.selected_value == value %}is-active{% endif %}"
                      data-value="{{ value | escape }}"
                      style="background-color:{{ value | downcase | replace: ' ','' }};"
                      title="{{ value }}"
                      aria-label="{{ value }}"
                    ></button>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <div class="lp__pills" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <button
                      class="lp__pill {% if option.selected_value == value %}is-active{% endif %}"
                      data-value="{{ value | escape }}"
                    >{{ value }}</button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- comment %} Hidden native select {% endcomment %}
        <select name="id" id="lp-variant-select" class="lp__native-select visually-hidden" form="lp-form">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}selected{% endif %}
              {% unless variant.available %}disabled{% endunless %}
              data-price="{{ variant.price }}"
              data-compare="{{ variant.compare_at_price }}"
              data-img="{{ variant.featured_image | image_url: width: 1200 }}"
            >{{ variant.title }}</option>
          {%- endfor -%}
        </select>
      {%- endunless -%}

      {%- comment %} Availability nudge {% endcomment %}
      {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 10 -%}
        <p class="lp__urgency">🔥 Only {{ current_variant.inventory_quantity }} left in stock!</p>
      {%- endif -%}

      {%- comment %} Add to cart form {% endcomment %}
      <form id="lp-form" action="/cart/add" method="post">
        <input type="hidden" name="id" value="{{ current_variant.id }}" class="lp__hidden-id">

        <div class="lp__qty-row">
          <label class="lp__qty-label" for="lp-qty">Qty</label>
          <div class="lp__qty-ctrl">
            <button type="button" class="lp__qty-btn" data-action="dec" aria-label="Decrease">−</button>
            <input id="lp-qty" type="number" name="quantity" value="1" min="1" aria-label="Quantity">
            <button type="button" class="lp__qty-btn" data-action="inc" aria-label="Increase">+</button>
          </div>
        </div>

        <button
          id="lp-atc"
          type="submit"
          class="lp__atc {% unless current_variant.available %}lp__atc--soldout{% endunless %}"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          <svg class="lp__atc-icon" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-13.5-5h14.36l1.5-8H4.21L3.84 3H1v2h2l3.6 7.59L5.25 15H19v-2H7.42l-1-2z"/></svg>
          {%- if current_variant.available -%}Add to Cart — {{ current_variant.price | money }}{%- else -%}Sold Out{%- endif -%}
        </button>
      </form>

      {%- comment %} Trust badge strip {% endcomment %}
      <div class="lp__trust">
        <div class="lp__trust-item">
          <svg viewBox="0 0 24 24"><path d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5z"/></svg>
          <span>Secure Payment</span>
        </div>
        <div class="lp__trust-item">
          <svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4z"/></svg>
          <span>Free UK Delivery £150+</span>
        </div>
        <div class="lp__trust-item">
          <svg viewBox="0 0 24 24"><path d="M19 8l-4 4h3c0 3.31-2.69 6-6 6a5.87 5.87 0 0 1-2.8-.7l-1.46 1.46A7.93 7.93 0 0 0 12 20c4.42 0 8-3.58 8-8h3l-4-4zM6 12c0-3.31 2.69-6 6-6 1.01 0 1.97.25 2.8.7l1.46-1.46A7.93 7.93 0 0 0 12 4c-4.42 0-8 3.58-8 8H1l4 4 4-4H6z"/></svg>
          <span>30-Day Returns</span>
        </div>
        <div class="lp__trust-item">
          <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.11 0-2 .89-2 2v12c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg>
          <span>Buy Now, Pay Later</span>
        </div>
      </div>

      {%- comment %} Accordions {% endcomment %}
      <div class="lp__accordions">
        <div class="lp__acc">
          <button class="lp__acc-trigger is-open" aria-expanded="true" aria-controls="lp-desc">
            Product Details <svg viewBox="0 0 24 24" class="lp__acc-icon"><path d="M7 10l5 5 5-5z"/></svg>
          </button>
          <div id="lp-desc" class="lp__acc-panel">
            {{ product.description }}
          </div>
        </div>
        <div class="lp__acc">
          <button class="lp__acc-trigger" aria-expanded="false" aria-controls="lp-ship">
            Shipping & Returns <svg viewBox="0 0 24 24" class="lp__acc-icon"><path d="M7 10l5 5 5-5z"/></svg>
          </button>
          <div id="lp-ship" class="lp__acc-panel" hidden>
            <p>Free standard delivery on orders over £150. Express and next-day options available at checkout. Returns accepted within 30 days — unused items in original packaging only. Contact us at hello@propcenter.co.uk.</p>
          </div>
        </div>
        <div class="lp__acc">
          <button class="lp__acc-trigger" aria-expanded="false" aria-controls="lp-hire">
            Hire This Item <svg viewBox="0 0 24 24" class="lp__acc-icon"><path d="M7 10l5 5 5-5z"/></svg>
          </button>
          <div id="lp-hire" class="lp__acc-panel" hidden>
            <p>Need this for just one event? We offer flexible hire packages across the UK. <a href="/pages/contact" style="color:#c9a96e;">Get in touch</a> with your event date, location, and required duration for a tailored quote.</p>
          </div>
        </div>
      </div>

    </div>{%- comment %} /.lp__info {% endcomment %}
  </div>{%- comment %} /.lp__layout {% endcomment %}

  {%- comment %} ── JUDGE.ME FULL REVIEW WIDGET ── {% endcomment %}
  <div id="lp-reviews" class="lp__reviews-section">
    <h2 class="lp__reviews-heading">Customer Reviews</h2>
    {%- render 'judgeme_widgets', widget_type: 'judgeme_reviews', jm_style: '', concierge_install: true, product: product -%}
  </div>

  {%- comment %} ── YOU MIGHT ALSO LIKE ── {% endcomment %}
  {%- assign rel_col = product.collections.first -%}
  {%- if rel_col -%}
    <section class="lp__related">
      <h2 class="lp__related-heading">You Might Also Like</h2>
      <div class="lp__related-grid">
        {%- for rel in rel_col.products limit: 5 -%}
          {%- unless rel.id == product.id -%}
            <a class="lp__rel-card" href="{{ rel.url }}">
              <div class="lp__rel-img">
                <img src="{{ rel.featured_image | image_url: width: 600 }}"
                     alt="{{ rel.featured_image.alt | escape }}" width="600" height="600" loading="lazy">
                {%- if rel.images.size > 1 -%}
                  <img class="lp__rel-img-hover" src="{{ rel.images[1] | image_url: width: 600 }}"
                       alt="{{ rel.images[1].alt | escape }}" width="600" height="600" loading="lazy">
                {%- endif -%}
              </div>
              <p class="lp__rel-title">{{ rel.title }}</p>
              <p class="lp__rel-price">
                {%- if rel.compare_at_price > rel.price -%}
                  <s>{{ rel.compare_at_price | money }}</s>
                {%- endif -%}
                {{ rel.price | money }}
              </p>
            </a>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

</div>{%- comment %} /.lp {% endcomment %}

{%- comment %} ── STYLES ── {% endcomment %}
<style>
/* ─── Reset ─────────────────────────────────────────── */
.lp *, .lp *::before, .lp *::after { box-sizing: border-box; }
.visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; }

/* ─── Tokens ─────────────────────────────────────────── */
.lp {
  --gold:  #c9a96e;
  --gold-d: #b8955c;
  --dark:  #1a1a1a;
  --warm:  #f8f6f3;
  --muted: #888;
  --line:  #e8e4df;
  font-family: var(--font-body-family, system-ui, sans-serif);
  color: var(--dark);
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px 96px;
}

/* ─── Breadcrumb ─────────────────────────────────────── */
.lp__breadcrumb ol { display: flex; flex-wrap: wrap; gap: 6px; list-style: none; margin: 0; padding: 20px 0; font-size: 12px; color: var(--muted); }
.lp__breadcrumb li + li::before { content: '/'; margin-right: 6px; }
.lp__breadcrumb a { color: var(--muted); text-decoration: none; }
.lp__breadcrumb a:hover { color: var(--dark); }

/* ─── Layout ─────────────────────────────────────────── */
.lp__layout {
  display: grid;
  grid-template-columns: 55% 1fr;
  gap: 56px;
  align-items: start;
}
@media (max-width: 900px) { .lp__layout { grid-template-columns: 1fr; gap: 32px; } }

/* ─── Gallery — vertical thumb strip + main ─────────── */
.lp__gallery {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 10px;
  position: sticky;
  top: 24px;
  align-self: start;
}
@media (max-width: 900px) {
  .lp__gallery {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
    position: static;
  }
}

/* Thumb strip */
.lp__thumbstrip {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 580px;
  overflow-y: auto;
  scrollbar-width: thin;
}
@media (max-width: 900px) {
  .lp__thumbstrip {
    flex-direction: row;
    max-height: none;
    overflow-x: auto;
    overflow-y: hidden;
    order: 2;
  }
}

.lp__thumb {
  border: 2px solid transparent;
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  padding: 0;
  background: var(--warm);
  flex-shrink: 0;
  transition: border-color .2s;
}
.lp__thumb.is-active, .lp__thumb:hover { border-color: var(--gold); }
.lp__thumb img { display: block; width: 72px; height: 72px; object-fit: cover; }
@media (max-width: 900px) { .lp__thumb img { width: 60px; height: 60px; } }

/* Main image */
.lp__main-img-wrap {
  position: relative;
  background: var(--warm);
  border-radius: 12px;
  overflow: hidden;
  aspect-ratio: 1;
}
.lp__main-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: opacity .3s ease;
}
.lp__badge-img {
  position: absolute; top: 14px; left: 14px; z-index: 2;
  background: var(--gold); color: #fff;
  font-size: 11px; font-weight: 700; letter-spacing: .08em;
  padding: 4px 10px; border-radius: 20px;
}
.lp__arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: rgba(255,255,255,.88); border: none; border-radius: 50%;
  width: 40px; height: 40px; cursor: pointer; font-size: 18px;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s;
}
.lp__arrow:hover { background: #fff; }
.lp__arrow--prev { left: 12px; }
.lp__arrow--next { right: 12px; }

/* ─── Info panel ─────────────────────────────────────── */
.lp__category {
  font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
  color: var(--gold); margin: 0 0 8px; font-weight: 600;
}
.lp__title {
  font-family: var(--font-heading-family, Georgia, serif);
  font-size: clamp(22px, 2.8vw, 34px);
  font-weight: 400; line-height: 1.2;
  margin: 0 0 16px; letter-spacing: .01em;
}

/* Stars */
.lp__reviews-row {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 18px; flex-wrap: wrap;
}
.lp__reviews-link {
  font-size: 13px; color: var(--muted);
  text-decoration: underline; text-decoration-color: transparent;
  transition: text-decoration-color .2s;
}
.lp__reviews-link:hover { text-decoration-color: var(--muted); }

/* Price */
.lp__price {
  display: flex; align-items: baseline; gap: 10px;
  flex-wrap: wrap; margin-bottom: 20px;
}
.lp__price-reg   { font-size: 28px; font-weight: 700; color: var(--dark); }
.lp__price-sale  { font-size: 28px; font-weight: 700; color: var(--gold); }
.lp__price-was   { font-size: 18px; color: var(--muted); text-decoration: line-through; }
.lp__save-badge  {
  background: var(--gold); color: #fff;
  font-size: 11px; font-weight: 700; letter-spacing: .08em;
  padding: 3px 10px; border-radius: 20px;
  align-self: center;
}

/* Feature list */
.lp__features {
  list-style: none; margin: 0 0 24px; padding: 0;
  display: flex; flex-direction: column; gap: 9px;
  border: 1px solid var(--line); border-radius: 10px;
  padding: 16px 18px;
  background: var(--warm);
}
.lp__features li {
  display: flex; align-items: center; gap: 10px;
  font-size: 13.5px; color: #444;
}
.lp__features svg {
  width: 16px; height: 16px; fill: var(--gold); flex-shrink: 0;
}

/* Variants */
.lp__variants { display: flex; flex-direction: column; gap: 18px; margin-bottom: 20px; }
.lp__option-label {
  font-size: 13px; text-transform: uppercase; letter-spacing: .08em;
  margin: 0 0 10px; font-weight: 500; color: #555;
}
.lp__option-label strong { font-weight: 700; color: var(--dark); text-transform: none; letter-spacing: 0; }
.lp__swatches, .lp__pills { display: flex; flex-wrap: wrap; gap: 8px; }
.lp__swatch {
  width: 30px; height: 30px; border-radius: 50%;
  border: 2.5px solid transparent; cursor: pointer;
  outline-offset: 3px; transition: outline .15s, border-color .15s;
}
.lp__swatch.is-active, .lp__swatch:hover { border-color: var(--gold); outline: 2px solid var(--gold); }
.lp__pill {
  padding: 8px 18px; border: 1.5px solid var(--line);
  border-radius: 6px; background: none; cursor: pointer;
  font-size: 14px; transition: border-color .15s, background .15s, color .15s;
}
.lp__pill.is-active, .lp__pill:hover {
  border-color: var(--gold); background: var(--gold); color: #fff;
}

/* Urgency nudge */
.lp__urgency {
  font-size: 13px; color: #c0392b; font-weight: 600;
  margin: 0 0 14px;
}

/* Qty + ATC */
.lp__qty-row {
  display: flex; align-items: center; gap: 14px; margin-bottom: 12px;
}
.lp__qty-label {
  font-size: 13px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .08em; flex-shrink: 0;
}
.lp__qty-ctrl {
  display: flex; align-items: center;
  border: 1.5px solid var(--line); border-radius: 8px; overflow: hidden;
}
.lp__qty-btn {
  width: 40px; height: 40px; background: var(--warm);
  border: none; cursor: pointer; font-size: 20px; line-height: 1;
  transition: background .15s;
}
.lp__qty-btn:hover { background: var(--line); }
.lp__qty-ctrl input {
  width: 52px; border: none; text-align: center; font-size: 16px;
  padding: 0; outline: none;
  -moz-appearance: textfield;
}
.lp__qty-ctrl input::-webkit-inner-spin-button,
.lp__qty-ctrl input::-webkit-outer-spin-button { -webkit-appearance: none; }

.lp__atc {
  width: 100%; padding: 17px 24px;
  background: var(--gold); color: #fff;
  font-size: 13px; font-weight: 700; letter-spacing: .14em;
  text-transform: uppercase; border: none; border-radius: 8px;
  cursor: pointer; transition: background .2s, transform .15s;
  display: flex; align-items: center; justify-content: center; gap: 10px;
  margin-bottom: 20px;
}
.lp__atc:hover:not(:disabled) { background: var(--gold-d); transform: translateY(-1px); }
.lp__atc--soldout, .lp__atc:disabled { background: #ccc; cursor: not-allowed; transform: none; }
.lp__atc-icon { width: 18px; height: 18px; fill: currentColor; flex-shrink: 0; }

/* Trust strip */
.lp__trust {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 12px; margin-bottom: 28px;
  padding: 18px; border: 1px solid var(--line);
  border-radius: 10px;
}
.lp__trust-item {
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; color: #555;
}
.lp__trust-item svg { width: 18px; height: 18px; fill: var(--gold); flex-shrink: 0; }

/* Accordions */
.lp__accordions { border-top: 1px solid var(--line); }
.lp__acc-trigger {
  width: 100%; background: none; border: none; border-bottom: 1px solid var(--line);
  padding: 16px 0; display: flex; justify-content: space-between; align-items: center;
  font-size: 13px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .09em; cursor: pointer; text-align: left; color: var(--dark);
}
.lp__acc-icon { width: 20px; height: 20px; fill: var(--dark); transition: transform .2s; flex-shrink: 0; }
.lp__acc-trigger.is-open .lp__acc-icon { transform: rotate(180deg); }
.lp__acc-panel {
  padding: 16px 0; font-size: 15px; line-height: 1.75; color: #444;
  border-bottom: 1px solid var(--line);
}
.lp__acc-panel p, .lp__acc-panel ul { margin: 0 0 12px; }
.lp__acc-panel ul { padding-left: 20px; }
.lp__acc-panel a { color: var(--gold); }

/* ─── Reviews section ────────────────────────────────── */
.lp__reviews-section { margin-top: 72px; padding-top: 48px; border-top: 1px solid var(--line); }
.lp__reviews-heading {
  font-family: var(--font-heading-family, Georgia, serif);
  font-size: 26px; font-weight: 400; margin: 0 0 32px;
  text-align: center; letter-spacing: .03em;
}

/* ─── Related products ───────────────────────────────── */
.lp__related { margin-top: 72px; padding-top: 48px; border-top: 1px solid var(--line); }
.lp__related-heading {
  font-family: var(--font-heading-family, Georgia, serif);
  font-size: 26px; font-weight: 400; text-align: center;
  margin: 0 0 36px; letter-spacing: .03em;
}
.lp__related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 20px;
}
.lp__rel-card { text-decoration: none; color: inherit; display: block; }
.lp__rel-img {
  aspect-ratio: 1; border-radius: 10px; overflow: hidden;
  background: var(--warm); position: relative; margin-bottom: 10px;
}
.lp__rel-img img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: opacity .35s, transform .45s;
  position: absolute; inset: 0;
}
.lp__rel-img-hover { opacity: 0; }
.lp__rel-card:hover .lp__rel-img img:first-child { opacity: 0; }
.lp__rel-card:hover .lp__rel-img-hover { opacity: 1; }
.lp__rel-card:hover .lp__rel-img img { transform: scale(1.04); }
.lp__rel-title { font-size: 14px; margin: 0 0 4px; line-height: 1.35; }
.lp__rel-price { font-size: 14px; font-weight: 700; color: var(--gold); margin: 0; }
.lp__rel-price s { font-weight: 400; color: var(--muted); margin-right: 4px; }
</style>

{%- comment %} ── SCRIPTS ── {% endcomment %}
<script>
(function () {
  const mainImg   = document.getElementById('lp-main-img');
  const thumbs    = document.querySelectorAll('.lp__thumb');
  const varSel    = document.getElementById('lp-variant-select');
  const priceEl   = document.getElementById('lp-price');
  const atcBtn    = document.getElementById('lp-atc');
  const hiddenId  = document.querySelector('#lp-form .lp__hidden-id');
  const qtyInput  = document.getElementById('lp-qty');

  // ── Thumbnails
  let currentIdx = 0;
  if (thumbs.length) {
    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => {
        thumbs.forEach(t => t.classList.remove('is-active'));
        thumb.classList.add('is-active');
        mainImg.src = thumb.dataset.src;
        mainImg.alt = thumb.dataset.alt;
        currentIdx  = i;
      });
    });
  }

  // ── Arrow nav
  document.querySelector('.lp__arrow--prev')?.addEventListener('click', () => {
    currentIdx = (currentIdx - 1 + thumbs.length) % thumbs.length;
    thumbs[currentIdx]?.click();
  });
  document.querySelector('.lp__arrow--next')?.addEventListener('click', () => {
    currentIdx = (currentIdx + 1) % thumbs.length;
    thumbs[currentIdx]?.click();
  });

  // ── Variant logic
  const optionContainers = document.querySelectorAll('[data-option-index]');

  function selectedOptions() {
    const opts = [];
    optionContainers.forEach(c => {
      const a = c.querySelector('.is-active');
      if (a) opts[parseInt(c.dataset.optionIndex)] = a.dataset.value;
    });
    return opts;
  }

  function syncVariant() {
    if (!varSel) return;
    const sel = selectedOptions();
    const match = Array.from(varSel.options).find(o => {
      const parts = o.textContent.trim().split(' / ');
      return sel.every((v, i) => parts[i]?.trim() === v);
    });
    if (!match) return;
    varSel.value  = match.value;
    hiddenId.value = match.value;
    updatePrice(match);
    if (match.dataset.img && match.dataset.img !== 'null') mainImg.src = match.dataset.img;
  }

  function fmt(cents) {
    return (cents / 100).toLocaleString('en-GB', { style: 'currency', currency: 'GBP' });
  }

  function updatePrice(opt) {
    const price   = parseInt(opt.dataset.price || 0);
    const compare = parseInt(opt.dataset.compare || 0);
    const avail   = !opt.disabled;
    let html = '';
    if (compare > price) {
      const pct = Math.round((compare - price) / compare * 100);
      html = `<span class="lp__price-sale">${fmt(price)}</span><span class="lp__price-was">${fmt(compare)}</span><span class="lp__save-badge">Save ${pct}%</span>`;
    } else {
      html = `<span class="lp__price-reg">${fmt(price)}</span>`;
    }
    priceEl.innerHTML = html;

    atcBtn.disabled = !avail;
    atcBtn.classList.toggle('lp__atc--soldout', !avail);
    if (avail) {
      atcBtn.innerHTML = `<svg class="lp__atc-icon" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-13.5-5h14.36l1.5-8H4.21L3.84 3H1v2h2l3.6 7.59L5.25 15H19v-2H7.42l-1-2z"/></svg>Add to Cart — ${fmt(price)}`;
    } else {
      atcBtn.textContent = 'Sold Out';
    }
  }

  optionContainers.forEach(c => {
    c.addEventListener('click', e => {
      const btn = e.target.closest('.lp__pill, .lp__swatch');
      if (!btn) return;
      c.querySelectorAll('.is-active').forEach(el => el.classList.remove('is-active'));
      btn.classList.add('is-active');
      const valSpan = document.querySelector(`.lp__option-val[data-opt="${c.dataset.optionIndex}"]`);
      if (valSpan) valSpan.textContent = btn.dataset.value;
      syncVariant();
    });
  });

  // ── Qty controls
  qtyInput?.closest('.lp__qty-ctrl')?.querySelectorAll('.lp__qty-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      let v = parseInt(qtyInput.value) || 1;
      qtyInput.value = btn.dataset.action === 'inc' ? v + 1 : Math.max(1, v - 1);
    });
  });

  // ── Accordions
  document.querySelectorAll('.lp__acc-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const panel  = document.getElementById(trigger.getAttribute('aria-controls'));
      const isOpen = trigger.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', isOpen);
      panel.hidden = !isOpen;
    });
  });
})();
</script>
